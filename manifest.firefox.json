{
  "manifest_version": 3,
  "name": "智能填表助手",
  "version": "1.0",
  "description": "集成DeepSeek AI的智能表单填写助手",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "http://*/*",
    "https://*/*",
    "file://*/*"  
  ],
  "background": {
    "scripts": ["background.js"]                     
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "打开智能填表助手"
  },
  "sidebar_action": {                                 
    "default_title": "智能填表助手",
    "default_panel": "sidebar.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "browser_specific_settings": {                      
    "gecko": {
      "id": "fill-assistant@example.org",
      "strict_min_version": "109.0"
    }
  }
}